# Copie este arquivo para ".env" (mesma pasta) antes de subir o container.
#   cd docker
#   copy .env.example .env     (Windows)
#
# Os valores abaixo sao apenas para o ambiente de avaliacao/local.

# Senha de SYS e SYSTEM no Oracle
ORACLE_PASSWORD=Oracle123

# Usuario/owner da aplicacao (deve casar com [Database].User do Granja.ini)
APP_USER=GRANJA
APP_USER_PASSWORD=granja123
